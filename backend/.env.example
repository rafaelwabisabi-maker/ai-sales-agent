# Required
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins (REQUIRED in production)
ALLOWED_ORIGINS=https://client-website.com

# Logging
LOG_LEVEL=info

# Webhook security
WEBHOOK_SECRET=change-me-to-random-string

# Database path (default: ./data/conversations.db)
DB_PATH=./data/conversations.db

# Cal.com
CALCOM_API_KEY=cal_...
CALCOM_EVENT_SLUG=discovery-call
CALCOM_USERNAME=your-username

# N8N Webhook (for lead capture)
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/lead-captured

# Google Sheets (optional — N8N handles this, but direct is faster for MVP)
GOOGLE_SHEET_ID=your-sheet-id

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
